# Timeframe — Environment Variables
# Copy this file to .env.local and fill in values.
# Do NOT commit real credentials. This file uses blank placeholders.

# ─── App ─────────────────────────────────────────────────
# Public URL used for sitemap, robots.txt, and OG metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Supabase / PostgreSQL) ─────────────────────
# Supabase project URL (server-side only).
# Used by src/lib/db/index.ts — NEXT_PUBLIC_ variant takes precedence.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
# Supabase service role key (server-side only, never commit).
SUPABASE_SERVICE_KEY=

# ─── Cache (Upstash Redis) ───────────────────────────────
# Optional: if unset, the cache service falls back to an in-memory Map.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Archive (Wayback Machine) ───────────────────────────
# Override the default Wayback CDX base URL (optional).
WAYBACK_CDX_BASE_URL=http://web.archive.org/cdx/search/cdx
